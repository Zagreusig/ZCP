fn program() -> int {
   have x = 0;
   have y: char = 'c';
   have z = 'Y';
   have nwln = 'n';

   println("Inside the program");
   println(z);

   while (z == 'y' || z == 'Y') {
      println("Enter a number: ");
      x = readi();
      println("Enter a letter: ");
      y = readc();
      nwln = readc();


      println("Your number: ");
      println(x);
      println("Your letter: ");
      println(y);

      println(" ");
      println("Would you like to go again?: ");
      z = readc();
      nwln = readc();
   }

   return 0;
}