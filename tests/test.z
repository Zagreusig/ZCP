fn mult(int a, int b) -> int {
   return a * b;
}

fn funny(int a) -> int {
   for (have i = 0; i < 10; i++) {
      if (i % 2 == 0) {
         return a * 5;
      }
   }
   return a % 3;
} 

fn main(): int {
   have x = 3;
   have arr: int[5];

   for (have i = 0; i < 5; i++) {
      arr[i] = funny(mult(x, i));
   }
   for (have i = 0; i < 5; i++) {
      println(arr[i]);
   }

   return x / 3;
}