fn greet(str s) {
   println(s);
}

fn foo(str a, str b) {
   println(a);
   println(b);
}

fn bar(int a, str b) {
   println(a);
   println(b);
}

fn third(int a, char b, str c) {
   println(a);
   println(b);
   println(c);
}

func main() ->int {
   have s: str = "Hello there";
   foo("hi", "yuh");
   foo(s, "hi");
   bar(5, "hello");
   bar((5 + 6) * 2, "bar!");
   third(1, 'a', s);

   return 0;
}